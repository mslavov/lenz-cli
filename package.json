    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "skillflag": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
