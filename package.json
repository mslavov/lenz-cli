{
  "name": "lenz-cli",
  "version": "1.0.0",
  "description": "CLI + agent skill for Lenz verified claims fact-checking API",
  "type": "module",
  "bin": {
    "lenz": "./dist/index.js",
    "lenz-cli": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
